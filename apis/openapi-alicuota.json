                        "example": 13
                    },
                    {
                        "name": "regimenAR",
                        "in": "query",
                        "description": "Régimen ('R' o 'P')",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "R"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consulta procesada correctamente",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ConsultaAlicuotaComprobanteResponseDTO"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Error de validación",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RestFullErrorDTO"
                                },
                                "examples": {
                                    "CUIT inválida": {
                                        "summary": "Error por CUIT inválida",
                                        "description": "Se produce cuando la CUIT no tiene el formato correcto",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "La CUIT del Contribuyente 2012345678 no tiene el formato correcto"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    },
                                    "Actividad inválida": {
                                        "summary": "Error por actividad inválida",
                                        "description": "Se produce cuando la actividad no es válida (13, 14 o 15)",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "La actividad 16 no es válida. Valores permitidos: 13, 14, 15"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    },
                                    "Régimen inválido": {
                                        "summary": "Error por régimen inválido",
                                        "description": "Se produce cuando el régimen no es válido (R o P)",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "El régimen X no es válido. Valores permitidos: R, P"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error inesperado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RestFullErrorDTO"
                                },
                                "examples": {
                                    "Error interno": {
                                        "summary": "Error interno del servidor",
                                        "description": "Se produce cuando ocurre un error inesperado en el servidor",
                                        "value": {
                                            "status": "INTERNAL_SERVER_ERROR",
                                            "message": "Error: TX-20250915-134530",
                                            "errors": [
                                                " Mensaje: Error al procesar la consulta manual de alícuota"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/alicuotas/fechaExacta": {
            "get": {
                "tags": [
                    "consulta-alicuota-fecha-exacta-controller"
                ],
                "summary": "Consulta de alícuota válida en la fecha seleccionada ",
                "description": "Consulta de alícuota válida en la fecha seleccionada.",
                "operationId": "consultar_3",
                "parameters": [
                    {
                        "name": "fecha",
                        "in": "query",
                        "description": "Fecha desde (yyyy-MM-dd)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "date"
                        },
                        "example": "2025-02-12"
                    },
                    {
                        "name": "cuitContribuyente",
                        "in": "query",
                        "description": "CUIT del Contribuyente (11 dígitos)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 27123456789
                    },
                    {
                        "name": "actividadAR",
                        "in": "query",
                        "description": "Actividad del Agente (13, 14 o 15)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 13
                    },
                    {
                        "name": "regimenAR",
                        "in": "query",
                        "description": "Régimen ('R' o 'P')",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "R"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consulta procesada correctamente",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ConsultaAlicuotaComprobanteResponseDTO"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Error de validación",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RestFullErrorDTO"
                                },
                                "examples": {
                                    "CUIT inválida": {
                                        "summary": "Error por CUIT inválida",
                                        "description": "Se produce cuando la CUIT no tiene el formato correcto",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "La CUIT del Contribuyente 2012345678 no tiene el formato correcto"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    },
                                    "Actividad inválida": {
                                        "summary": "Error por actividad inválida",
                                        "description": "Se produce cuando la actividad no es válida (13, 14 o 15)",
                                        "value": {
                                            "status": "BAD_REQUEST",
