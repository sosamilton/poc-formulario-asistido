                                            "errors": [
                                                "La actividad 16 no es válida. Valores permitidos: 13, 14, 15"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas/manual"
                                        }
                                    },
                                    "Régimen inválido": {
                                        "summary": "Error por régimen inválido",
                                        "description": "Se produce cuando el régimen no es válido (R o P)",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "El régimen X no es válido. Valores permitidos: R, P"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
