{
    "openapi": "3.0.1",
    "info": {
        "title": "Servicios Alicuotas API",
        "description": "Servicios de consultas de alicuotas en Padrones",
        "license": {
            "name": "Apache 2.0",
            "url": "http://springdoc.org"
        },
        "version": "v0.0.1"
    },
    "externalDocs": {
        "description": "Servicios Alicuotas API",
        "url": "https://gitlab.arba.gov.ar/sisweb/serviciosalicuotasapi"
    },
    "servers": [
        {
            "url": "/ServiciosAlicuotasAPI"
        }
    ],
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "paths": {
        "/alicuotas": {
            "get": {
                "tags": [
                    "consulta-alicuota-controller"
                ],
                "summary": "Consulta la alícuota de un contribuyente",
                "description": "Retorna la alícuota aplicable según CUIT del agente, actividad, régimen y CUIT del contribuyente.",
                "operationId": "consultar",
                "parameters": [
                    {
                        "name": "cuitAR",
                        "in": "query",
                        "description": "CUIT del Agente de Recaudación (11 dígitos)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 20304050607
                    },
                    {
                        "name": "actividadAR",
                        "in": "query",
                        "description": "Actividad del Agente (13, 14 o 15)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 13
                    },
                    {
                        "name": "regimenAR",
                        "in": "query",
                        "description": "Régimen ('R')",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "example": "R"
                    },
                    {
                        "name": "cuitContribuyente",
                        "in": "query",
                        "description": "CUIT del Contribuyente (11 dígitos)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 27123456789
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consulta procesada correctamente",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/ConsultaAlicuotaResponseDTO"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Error de validación",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RestFullErrorDTO"
                                },
                                "examples": {
                                    "CUIT inválida": {
                                        "summary": "Error por CUIT inválida",
                                        "description": "Se produce cuando la CUIT no tiene el formato correcto",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "La CUIT del Agente 2012345678 no tiene el formato correcto"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas"
                                        }
                                    },
                                    "Actividad inválida": {
                                        "summary": "Error por actividad inválida",
                                        "description": "Se produce cuando la actividad no es válida (13, 14 o 15)",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "La actividad 16 no es válida. Valores permitidos: 13, 14, 15"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas"
                                        }
                                    },
                                    "Régimen inválido": {
                                        "summary": "Error por régimen inválido",
                                        "description": "Se produce cuando el régimen no es válido (R o P)",
                                        "value": {
                                            "status": "BAD_REQUEST",
                                            "message": "Error de aplicación",
                                            "errors": [
                                                "El régimen X no es válido. Valores permitidos: R, P"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error inesperado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RestFullErrorDTO"
                                },
                                "examples": {
                                    "Error interno": {
                                        "summary": "Error interno del servidor",
                                        "description": "Se produce cuando ocurre un error inesperado en el servidor",
                                        "value": {
                                            "status": "INTERNAL_SERVER_ERROR",
                                            "message": "Error: TX-20250915-134530",
                                            "errors": [
                                                " Mensaje: Error al procesar la consulta de alícuota"
                                            ],
                                            "timestamp": "2025-09-15T13:45:30",
                                            "path": "/alicuotas"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/alicuotas/regimen/consultar": {
            "get": {
                "tags": [
                    "consulta-regimen-controller"
                ],
                "summary": "Devuelve régimen vigente para la actividad seleccionada",
                "operationId": "consultar_1",
                "parameters": [
                    {
                        "name": "actividadAR",
                        "in": "query",
                        "description": "Actividad del Agente",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 13
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ConsultaRegimenResponseDTO"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/alicuotas/manual": {
            "get": {
                "tags": [
                    "consulta-alicuota-manual-controller"
