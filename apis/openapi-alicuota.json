                            "type": "integer",
                            "format": "int64"
                        },
                        "example": 27123456789
                    },
                    {
                        "name": "actividadAR",
                        "in": "query",
                        "description": "Actividad del Agente (13, 14 o 15)",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
