# Versión de Corteza que quieras probar
VERSION=2024.9

# Configuración general
DOMAIN=localhost:18080

# Configuración de la DB
DB_DSN=postgres://corteza:corteza@db:5432/corteza?sslmode=disable

# Server settings
HTTP_WEBAPP_ENABLED=true
ACTIONLOG_ENABLED=false

# Opciones de SMTP si necesitas notificaciones (puedes desactivarlas)
SMTP_HOST=mailpit:1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM='"Corteza" <noreply@localhost>'
