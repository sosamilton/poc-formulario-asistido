# Configuración de entorno

# Modo de autenticación: 'mock' para desarrollo, 'keycloak' para producción
VITE_AUTH_MODE=mock

# URL del backend Windmill
VITE_WINDMILL_URL=http://localhost:8000
VITE_WINDMILL_WORKSPACE=arba

# URL de Form.io
VITE_FORMIO_URL=http://localhost:3001

# Keycloak (solo para producción)
# VITE_KEYCLOAK_URL=https://keycloak.example.com
# VITE_KEYCLOAK_REALM=tributario
# VITE_KEYCLOAK_CLIENT_ID=formio-frontend
