{
  "title": "Presentar declaración jurada mensual",
  "logoPosition": "right",
  "pages": [
    {
      "name": "declaracion",
      "elements": [
        {
          "type": "html",
          "name": "info_contribuyente",
          "html": "<div class='contribuyente-info'><div class='info-row'><span class='label'>CUIT</span><span class='value'>30-3456736-8 - Blabla S.A</span></div><div class='info-row'><span class='label'>Actividad</span><span class='value'>Servicios de diseño especializado (741000)</span></div></div>"
        },
        {
          "type": "dropdown",
          "name": "periodo",
          "title": "Período a declarar",
          "isRequired": true,
          "choices": [
            { "value": "2026-02", "text": "Febrero 2026" },
            { "value": "2026-01", "text": "Enero 2026" },
            { "value": "2025-12", "text": "Diciembre 2025" },
            { "value": "2025-11", "text": "Noviembre 2025" },
            { "value": "2025-10", "text": "Octubre 2025" }
          ],
          "defaultValue": "2026-02"
        },
        {
          "type": "text",
          "name": "monto_declarar",
          "title": "Monto a declarar",
          "description": "Ingrese el monto total de ingresos brutos del período",
          "isRequired": true,
          "inputType": "number",
          "min": 0,
          "placeholder": "$0,00",
          "visibleIf": "{periodo} != '2026-01'"
        },
        {
          "type": "html",
          "name": "aviso_rectificacion",
          "html": "<div class='warning-box'><svg xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='#f57c00' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='12' r='10'/><line x1='12' y1='8' x2='12' y2='12'/><line x1='12' y1='16' x2='12.01' y2='16'/></svg><p>Ya tenés una declaración jurada para este mes. Podés rectificarla si es que la querés volver a hacer.</p></div>",
          "visibleIf": "{periodo} = '2026-01'"
        }
      ]
    }
  ],
  "showQuestionNumbers": "off",
  "showProgressBar": "off",
  "showNavigationButtons": true,
  "completeText": "Continuar",
  "requiredText": "*",
  "questionErrorLocation": "bottom",
  "widthMode": "static",
  "width": "100%"
}
